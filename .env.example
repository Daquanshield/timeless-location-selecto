# Mapbox - Get your token from https://mapbox.com/account/tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Supabase - Get from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# n8n Webhook URL (for submission callback)
N8N_WEBHOOK_URL=https://timelesstrust.app.n8n.cloud/webhook/location-selected
N8N_WEBHOOK_SECRET=your_webhook_secret_here
